{
  "name": "hassanelzarkawy/origin",
  "description": "Modular architecture for Laravel applications",
  "version": "0.0.1",
  "keywords": [
    "laravel",
    "modules",
    "modular",
    "architecture"
  ],
  "license": "MIT",
  "type": "library",
  "authors": [
    {
      "name": "Hassan El-Zarkawy",
      "email": "hassan.elzarkawy@gmail.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/console": "^11.0|^12.0|^13.0",
    "illuminate/filesystem": "^11.0|^12.0|^13.0",
    "illuminate/support": "^11.0|^12.0|^13.0",
    "wikimedia/composer-merge-plugin": "^2.0"
  },
  "require-dev": {
    "driftingly/rector-laravel": "^2.4",
    "laravel/pint": "^1.29",
    "orchestra/testbench": "^9.0|^10.0|^11.0",
    "pestphp/pest": "^3.0",
    "pestphp/pest-plugin-laravel": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Origin\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Origin\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/pest",
    "test-coverage": "vendor/bin/pest --coverage",
    "format": [
      "./vendor/bin/rector",
      "./vendor/bin/pint"
    ]
  },
  "extra": {
    "laravel": {
      "providers": [
        "Origin\\ModularServiceProvider"
      ],
      "aliases": {
        "Modular": "Origin\\Facades\\Modular"
      }
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "wikimedia/composer-merge-plugin": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
